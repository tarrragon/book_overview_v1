# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# dotenv environment variables
.env
.env.test
.env.*.local

# Logs
logs/
*.log
*.log.*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
# W14-042: per-ticket-file advisory lock 殘留（fcntl.flock，crash 自動釋放）
*.lock
# W1-018.1: 測試誤把 mocked get_ticket_path（MagicMock）傳入 file_lock 時，
# os.fspath 合成出 "MagicMock/<call>/<id>" 路徑而產生的垃圾目錄；file_lock
# 已加 input validation 防再產生，此為第二道防護（防誤 git add 復發）。
MagicMock/

# Directory for instrumented libs generated by jscoverage/Jest
coverage/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# 打包產物（npm run package 產出的可分發 ZIP）
dist/

# 測試者發布包（npm run package:release）：ZIP 為建置產物不入版控，
# README.md 為安裝說明可入版控（故只忽略 *.zip 而非整個 release/）
release/*.zip

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# macOS
.DS_Store

# Others
dist/
build/
tmp/
temp/
.cache/
.serena/

# Python bytecode cache
__pycache__/

# Python build artifacts（uv tool install skill 產生的 egg-info 目錄）
*.egg-info/

# Claude Hook System logs (auto-generated)
# 覆蓋根目錄 .claude/hook-logs/ 與嵌套 skill 目錄（如 .claude/skills/ticket/.claude/hook-logs/）
**/hook-logs/

# Claude sync state (local only)
.claude/.sync-state.json

# Claude sync local-only / per-project settings 漂移補齊（0.19.1-W1-030）
# 與 sync_exclude_manifest LOCAL_ONLY_PATTERNS 對齊：這些是各專案個別管理的
# local-only / runtime / 工具產物，不應跨專案同步，也不應被誤推或被 push
# clean-check 誤判。已 git tracked 者（如 .version-release.yaml / settings.local.json /
# sync-preserve.yaml）由 manifest should_exclude 於 push 時過濾，此處 ignore 防止
# 未來新增的同類 untracked 變體污染工作區狀態。
.claude/.zhtw-mcp-skip
.claude/.version-release.yaml
.claude/sync-preserve.yaml
.claude/sync-skills.yaml
.claude/settings.local.json
.claude/.venv/
.claude/.pytest_cache/
.claude/.sync-conflicts/
# nested skill 目錄下的同類 local-only 變體（如 .claude/skills/*/.version-release.yaml）
**/.zhtw-mcp-skip
**/.pytest_cache/

# Claude handoff (session-bound local-only, sync class C — 不版控、不同步)
# 對齊 sync manifest LOCAL_ONLY_PATTERNS 的 "handoff"（0.19.1-W1-032）
.claude/handoff/

# Claude tool results (runtime state, auto-managed by hooks)
.claude/tool-results/

# Claude dispatch tracker (runtime state, auto-managed by hooks)
.claude/dispatch-active.json
.claude/dispatch-active.lock

# Claude PM status (runtime state, auto-managed by hooks)
.claude/pm-status.json

# Claude PM intervention markers (runtime state)
.claude/ARCHITECTURE_REVIEW_REQUIRED
.claude/TASK_AVOIDANCE_FIX_MODE
.claude/PM_INTERVENTION_REQUIRED

# Claude hook state (runtime state, auto-managed by hooks)
.claude/hook-state/

# Claude session state markers (runtime state, written by session-start hooks)
.claude/state/

# Claude scheduled tasks runtime lock (session-local)
.claude/scheduled_tasks.lock

# Claude worktrees (agent-generated, session-local)
.claude/worktrees/

# Pending handoff recovery workdirs (session-local)
（待恢復 handoff）*/

# Claude migration backups (ticket migrate auto-generated)
.claude/migration-backups/

# Claude 專案產物（per-project，非框架資產，不跨專案 sync）
.claude/analyses/
.claude/plans/

# Project-level backup directories (smart_fix / manual snapshots)
.backup/
backups/

# E2E test screenshots (generated artifacts)
tests/e2e/screenshots/

# CodeGraph MCP index (per-developer local index, see docs/development-setup.md)
.codegraph/

# Editor / tooling backup snapshots (prevent regeneration of *.backup-N / *.bak / *.tmp
# garbage files; 0.19.1-W1-005.3 cleaned 122 such files from tests/)
*.backup-*
*.bak
*.tmp

# Coverage report directories (generated artifacts, only coverage/ was gitignored)
coverage-*/

# One-off lint/fix scripts and reports (1.2.0-W2-004 cleanup)
check-*.js
run-*.js
*-fix-report*.md
*-fix-summary*.md
*-fix-progress*.md

# Stale AI tool configs
.codex/
.kiro/
.cursorrules
cursorrule
AGENTS.md
