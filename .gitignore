# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# dotenv environment variables
.env
.env.test
.env.*.local

# Logs
logs/
*.log
*.log.*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
# W14-042: per-ticket-file advisory lock 殘留（fcntl.flock，crash 自動釋放）
*.lock

# Directory for instrumented libs generated by jscoverage/Jest
coverage/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# 打包產物（npm run package 產出的可分發 ZIP）
dist/

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# macOS
.DS_Store

# Others
dist/
build/
tmp/
temp/
.cache/
.serena/

# Python bytecode cache
__pycache__/

# Claude Hook System logs (auto-generated)
.claude/hook-logs/

# Claude sync state (local only)
.claude/.sync-state.json

# Claude handoff archives (session-local)
.claude/handoff/archive/

# Claude dispatch tracker (runtime state, auto-managed by hooks)
.claude/dispatch-active.json
.claude/dispatch-active.lock

# Claude hook state (runtime state, auto-managed by hooks)
.claude/hook-state/

# Claude session state markers (runtime state, written by session-start hooks)
.claude/state/

# Claude scheduled tasks runtime lock (session-local)
.claude/scheduled_tasks.lock

# Claude worktrees (agent-generated, session-local)
.claude/worktrees/

# Pending handoff recovery workdirs (session-local)
（待恢復 handoff）*/

# Claude migration backups (ticket migrate auto-generated)
.claude/migration-backups/

# Project-level backup directories (smart_fix / manual snapshots)
.backup/
backups/

# E2E test screenshots (generated artifacts)
tests/e2e/screenshots/
