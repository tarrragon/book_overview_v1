  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/startup-check-hook.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/prompt-submit-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/task-avoidance-detection-hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/check-5w1h-compliance.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/task-avoidance-block-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash.*git commit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/pre-commit-hook.sh"
          }
        ]
      },
      {
        "matcher": "Bash.*npm test|Bash.*npx jest",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/pre-test-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/performance-monitor-hook.sh post-edit start"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/post-edit-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/code-smell-detection-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/architecture-debt-detection-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/auto-documentation-update-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/performance-monitor-hook.sh post-edit end"
          }
        ]
      },
      {
        "matcher": "Bash.*npm test|Bash.*npx jest",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/scripts/performance-monitor-hook.sh test start"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/post-test-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/performance-monitor-hook.sh test end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/check-todos.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./.claude/scripts/stop-hook.sh"
          },
          {
            "type": "command",
            "command": "./.claude/scripts/pm-trigger-hook.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/check-todos.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}